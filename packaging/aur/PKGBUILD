# Maintainer: Real-Fruit-Snacks
pkgname=conduit
pkgver=1.0.0
pkgrel=1
pkgdesc="Network relay with integrated process masquerading, built on SOCAT"
arch=('x86_64' 'aarch64')
url="https://real-fruit-snacks.github.io/Conduit"
license=('GPL2' 'custom:OpenSSL-exception')
depends=('openssl' 'readline')
makedepends=('gcc' 'make')
provides=('conduit')
conflicts=('socat')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/Real-Fruit-Snacks/Conduit/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')  # Will be updated after release

build() {
    cd "${srcdir}/Conduit-${pkgver}/socat-repo"

    ./configure \
        --prefix=/usr \
        --mandir=/usr/share/man

    make conduit
}

check() {
    cd "${srcdir}/Conduit-${pkgver}"

    # Basic functionality tests
    ./socat-repo/conduit -h > /dev/null
    ./socat-repo/conduit -V > /dev/null
}

package() {
    cd "${srcdir}/Conduit-${pkgver}"

    # Install binary
    install -Dm755 socat-repo/conduit "${pkgdir}/usr/bin/conduit"

    # Install man page
    install -Dm644 conduit.1 "${pkgdir}/usr/share/man/man1/conduit.1"

    # Install bash completion
    install -Dm644 completions/conduit.bash \
        "${pkgdir}/usr/share/bash-completion/completions/conduit"

    # Install zsh completion
    install -Dm644 completions/_conduit \
        "${pkgdir}/usr/share/zsh/site-functions/_conduit"

    # Install examples
    install -dm755 "${pkgdir}/usr/share/conduit/examples"
    install -Dm755 examples/*.sh "${pkgdir}/usr/share/conduit/examples/"

    # Install documentation
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    install -Dm644 INSTALL.md "${pkgdir}/usr/share/doc/${pkgname}/INSTALL.md"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
